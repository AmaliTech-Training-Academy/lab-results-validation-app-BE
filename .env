# .env - local development environment variables for labresultsvalidator
# These variables match the placeholders used in src/main/resources/application.properties
# NOTE: Loading .env is environment/tooling-specific. IntelliJ run configurations can reference this file
# or you can export these variables in your shell before running the app.

# Database connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=lab_results_db
DB_USER=labresults_user
DB_PASSWORD=labresults_pass


